# MD041 - First line in a file should be a top-level heading

CompileFlags:
  Add:
    - -std=c++20
    - -isystem
    - imgui
    - -isystem
    - imgui/backends
    - -isystem
    - thirdParty/nfd/src/include
    - -I/opt/homebrew/include
    - -DGL_SILENCE_DEPRECATION

---

If:
  PathMatch: (imgui/.*|thirdParty/.*)
Diagnostics:
  Suppress: '*'
